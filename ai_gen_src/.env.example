APP_TIMEZONE=Asia/Ho_Chi_Minh
DATA_SOURCE=mock

# GreenNode AIP (OpenAI-compatible) — chat OpsOne §7.6.5
# URL mặc định nếu bỏ trống: https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_URL=
LLM_API_KEY=
