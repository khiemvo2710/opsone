# OpsOne API on GreenNode AgentBase — copy to .env.greennode and fill values.
# Generate from local .env:  .\scripts\prepare-greennode-env.ps1
# Do NOT set GREENNODE_CLIENT_ID / GREENNODE_CLIENT_SECRET / GREENNODE_AGENT_IDENTITY / GREENNODE_ENDPOINT_URL (auto-injected by runtime).

MYSQL_DSN=app:secret@tcp(YOUR_MYSQL_HOST:3306)/traffic_agent?parseTime=true&charset=utf8mb4&loc=Asia%2FHo_Chi_Minh
DATA_SOURCE=mock
API_ADDR=:8080
CORS_ORIGIN=*
DEV_AUTH_BYPASS=true
AGENT_LOCALE=vi-VN
APP_TIMEZONE=Asia/Ho_Chi_Minh
NOTIFICATION_MOCK=true
LLM_API_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=minimax/minimax-m2.5
LLM_TIMEOUT_SECONDS=30
