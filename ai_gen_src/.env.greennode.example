# OpsOne API on GreenNode AgentBase — copy to .env.greennode and fill values.
# Do NOT set GREENNODE_CLIENT_ID / GREENNODE_CLIENT_SECRET here (auto-injected by runtime).

MYSQL_DSN=app:secret@tcp(YOUR_MYSQL_HOST:3306)/traffic_agent?parseTime=true&charset=utf8mb4&loc=Asia%2FHo_Chi_Minh
DATA_SOURCE=mock
API_ADDR=:8080
CORS_ORIGIN=*
DEV_AUTH_BYPASS=true
AGENT_LOCALE=vi-VN
APP_TIMEZONE=Asia/Ho_Chi_Minh
NOTIFICATION_MOCK=true
