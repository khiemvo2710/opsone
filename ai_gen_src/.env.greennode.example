# OpsOne API on GreenNode AgentBase — copy to .env.greennode and fill values.
# Generate from local .env:  .\scripts\prepare-greennode-env.ps1
# Do NOT set GREENNODE_CLIENT_ID / GREENNODE_CLIENT_SECRET / GREENNODE_AGENT_IDENTITY / GREENNODE_ENDPOINT_URL (auto-injected by runtime).

# DBeaver JDBC may need allowPublicKeyRetrieval=true — do NOT add it here (Go driver rejects it).
MYSQL_DSN=khiemvt:<password>@tcp(YOUR_MYSQL_HOST:3306)/opsone?parseTime=true&charset=utf8mb4&loc=Asia%2FHo_Chi_Minh
DATA_SOURCE=mock
API_ADDR=:8080
CORS_ORIGIN=*
DEV_AUTH_BYPASS=true
AGENT_LOCALE=vi-VN
APP_TIMEZONE=Asia/Ho_Chi_Minh
NOTIFICATION_MOCK=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=<gmail-app-password>
SMTP_FROM=your-email@gmail.com
LLM_API_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=minimax/minimax-m2.5
LLM_TIMEOUT_SECONDS=30
